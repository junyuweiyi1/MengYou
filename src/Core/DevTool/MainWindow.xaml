<Window x:Class="MengYou.DevTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="梦游 - 开发者标定工具"
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen">
    <!-- 布局：顶部工具条 | 左侧标定列表 | 中央截图画布 | 右侧属性面板 -->
    <DockPanel LastChildFill="True">

        <!-- 顶部工具栏 -->
        <ToolBar DockPanel.Dock="Top">
            <Button Content="刷新窗口" Click="OnRefreshWindows" />
            <ComboBox x:Name="WindowsCombo" Width="300" DisplayMemberPath="Title" />
            <Separator />
            <Button Content="截图冻结" Click="OnCapture" />
            <Button Content="切换叠加显示" Click="OnToggleOverlay" />
            <Separator />
            <TextBlock Text="模板目录:" VerticalAlignment="Center" Margin="5,0" />
            <TextBlock x:Name="TemplateDirText" VerticalAlignment="Center" Foreground="Gray" />
            <Separator />
            <TextBlock Text="布局文件:" VerticalAlignment="Center" Margin="5,0" />
            <TextBlock x:Name="LayoutFileText" VerticalAlignment="Center" Foreground="Gray" />
        </ToolBar>

        <!-- 底部状态栏 -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="就绪" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="MousePosText" Text="Mouse: (-, -)" />
            </StatusBarItem>
        </StatusBar>

        <!-- 主体：三栏 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- 左：已标定列表 -->
            <DockPanel Grid.Column="0" Margin="4">
                <TextBlock DockPanel.Dock="Top" Text="已标定元素" FontWeight="Bold" />
                <Button DockPanel.Dock="Bottom" Content="删除所选" Click="OnDeleteSelected" />
                <ListBox x:Name="ElementsList" SelectionChanged="OnElementSelected">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Kind}" Width="45" Foreground="DarkBlue" />
                                <TextBlock Text="{Binding Key}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- 中：截图画布 -->
            <Border Grid.Column="1" Background="#222" BorderBrush="Gray" BorderThickness="1">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Grid x:Name="CanvasHost">
                        <Image x:Name="CaptureImage" Stretch="None" />
                        <Canvas x:Name="OverlayCanvas"
                                Background="Transparent"
                                MouseLeftButtonDown="OnCanvasMouseDown"
                                MouseMove="OnCanvasMouseMove"
                                MouseLeftButtonUp="OnCanvasMouseUp" />
                    </Grid>
                </ScrollViewer>
            </Border>

            <!-- 右：属性面板 -->
            <StackPanel Grid.Column="2" Margin="8">
                <TextBlock Text="当前选区" FontWeight="Bold" />
                <TextBlock x:Name="SelectionInfoText" Text="(未选择)" Foreground="Gray" Margin="0,4" />

                <TextBlock Text="键名 (如 HpNumber / TeamSlot.1.HpBar)" Margin="0,10,0,2" />
                <TextBox x:Name="KeyInput" />

                <TextBlock Text="类型" Margin="0,10,0,2" />
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="TypeRegion" Content="Region (区域)" IsChecked="True" GroupName="Type" Margin="0,0,10,0" />
                    <RadioButton x:Name="TypePoint" Content="Point (中心点)" GroupName="Type" />
                </StackPanel>

                <Button Content="保存到 UILayout.json" Margin="0,10,0,0" Click="OnSaveToLayout" />
                <Button Content="保存为模板 PNG (裁剪选区)" Margin="0,4,0,0" Click="OnSaveAsTemplate" />

                <Separator Margin="0,15" />
                <TextBlock Text="覆盖显示颜色说明" FontWeight="Bold" />
                <TextBlock Text="◻ 已标定 Region (绿)" Foreground="Lime" />
                <TextBlock Text="✕ 已标定 Point (黄)" Foreground="Yellow" />
                <TextBlock Text="▭ 当前拖拽选区 (红)" Foreground="Red" />
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
